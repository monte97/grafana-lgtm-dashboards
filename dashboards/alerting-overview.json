      },
      "options": {
        "alertInstanceLabelFilter": "severity=critical",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {
          "firing": true,
          "pending": false,
          "noData": false,
          "normal": false,
          "error": false
        },
        "viewMode": "stat"
