{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "uid": "alerting-overview",
  "title": "Alerting Overview",
  "description": "Current firing and pending Grafana alert rules with severity breakdown.",
  "tags": ["alerting", "observability"],
  "style": "dark",
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 36,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "links": [
    {
      "title": "Alert Rules", "type": "link",
      "url": "/alerting/list",
      "targetBlank": false, "icon": "bell"
    }
  ],
  "annotations": {"list": []},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1, "type": "row", "title": "Alert Status", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2, "type": "alertlist", "title": "Firing Alerts",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {"firing": true, "pending": false, "noData": false, "normal": false, "error": false},
        "viewMode": "stat"
      }
    },
    {
      "id": 3, "type": "alertlist", "title": "Pending Alerts",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {"firing": false, "pending": true, "noData": false, "normal": false, "error": false},
        "viewMode": "stat"
      }
    },
    {
      "id": 4, "type": "stat", "title": "Critical",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "loki", "uid": "loki"}, "expr": "count_over_time({from=\"state-history\"} | json | current=\"Alerting\" | severity=\"critical\" [2m])", "legendFormat": "Critical", "queryType": "instant"}]
    },
    {
      "id": 5, "type": "stat", "title": "Warning",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "loki", "uid": "loki"}, "expr": "count_over_time({from=\"state-history\"} | json | current=\"Alerting\" | severity=\"warning\" [2m])", "legendFormat": "Warning", "queryType": "instant"}]
    },
    {
      "id": 6, "type": "stat", "title": "Info",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "blue", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "loki", "uid": "loki"}, "expr": "count_over_time({from=\"state-history\"} | json | current=\"Alerting\" | severity=\"info\" [2m])", "legendFormat": "Info", "queryType": "instant"}]
    },
    {
      "id": 7, "type": "alertlist", "title": "System Status",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {"firing": true, "pending": false, "noData": false, "normal": false, "error": false},
        "viewMode": "stat"
      }
    },
    {
      "id": 10, "type": "row", "title": "Firing Alerts Detail", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}
    },
    {
      "id": 11, "type": "alertlist", "title": "Firing Alerts",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 6},
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {"firing": true, "pending": false, "noData": false, "normal": false, "error": false},
        "viewMode": "list"
      }
    },
    {
      "id": 20, "type": "row", "title": "Pending Alerts", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16}
    },
    {
      "id": 21, "type": "alertlist", "title": "Pending Alerts",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 17},
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {"firing": false, "pending": true, "noData": false, "normal": false, "error": false},
        "viewMode": "list"
      }
    },

    {
      "id": 30, "type": "row", "title": "Alert History", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Alert Firings Over Time",
      "description": "Number of alert state-change events per 5m bucket, by alert name. Requires Grafana Unified Alerting → Loki state history backend (GF_UNIFIED_ALERTING_STATE_HISTORY_BACKEND=loki).",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 26},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "gradientMode": "none", "drawStyle": "bars"},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum by (alertname) (count_over_time({from=\"state-history\"} | json | current = \"Alerting\" [5m]))",
          "legendFormat": "{{alertname}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 32,
      "type": "logs",
      "title": "Recent Alert State Changes",
      "description": "All alert state transitions (Normal ↔ Alerting ↔ Pending) written by Grafana Unified Alerting to Loki.",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 34},
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{from=\"state-history\"} | json | line_format \"[{{.current}}] {{.ruleUID}} (was: {{.previous}})\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
