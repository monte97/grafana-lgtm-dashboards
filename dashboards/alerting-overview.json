      }
    },
    {
      "id": 21,
      "type": "alertlist",
      "title": "Pending Alerts",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": {
          "firing": false,
          "pending": true,
          "noData": false,
          "normal": false,
          "error": false
        },
        "viewMode": "list"
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Alert History",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Alert Firings Over Time",
      "description": "Number of alert state-change events per 5m bucket, by alert name. Requires Grafana Unified Alerting \u2192 Loki state history backend (GF_UNIFIED_ALERTING_STATE_HISTORY_BACKEND=loki).",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "drawStyle": "bars"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (ruleUID) (count_over_time({from=\"state-history\"} | json | current = \"Alerting\" [$__range]))",
          "legendFormat": "{{alertname}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 32,
      "type": "logs",
      "title": "Recent Alert State Changes",
      "description": "All alert state transitions (Normal \u2194 Alerting \u2194 Pending) written by Grafana Unified Alerting to Loki.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{from=\"state-history\"} | json | line_format \"[{{.current}}] {{.ruleUID}} (was: {{.previous}})\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
