    "observability"
  ],
  "style": "dark",
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 36,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "links": [
    {
      "title": "Alert Rules",
